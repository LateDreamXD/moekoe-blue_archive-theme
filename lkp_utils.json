{
  "$schema": "node_modules/@latedream/moekoe-plugin-utils/schema/lkp_utils.json",
  "manifest": {
    "outpath": "dist/manifest.json"
  },
  "meta": {
    "name": "蔚蓝档案主题",
    "id": "blue_archive-theme",
    "min_moekoe_version": "1.6.2",
    "permissions": ["storage"],
    "injects": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.iife.js"],
        "css": ["css/index.css"],
        "run_at": "document_start"
      }
    ],
    "popup": {
      "html": "web/index.html",
      "icon": "assets/icon.png",
      "title": "设置"
    },
    "icons": {
      "162": "assets/icon.png"
    },
    "csp": [
      {
        "matches": ["<all_urls>"],
        "resources": [
          "css/*.css",
          "assets/fonts/index.css",
          "assets/fonts/Blueaka/*.css",
          "assets/fonts/Blueaka/*.woff2",
          "assets/fonts/Blueaka_Bold/*.css",
          "assets/fonts/Blueaka_Bold/*.woff2",
          "assets/wallpaper/*.png",
          "assets/wallpaper/*.jpg"
        ]
      }
    ],
    "generator": "moekoe-plugin-template-ts"
  }
}
